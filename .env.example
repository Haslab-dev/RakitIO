# Turso / libSQL database (client-only: this token is bundled and exposed to users)
VITE_TURSO_URL=libsql://your-db.turso.io
VITE_TURSO_AUTH_TOKEN=your-auth-token

# Optional default AI provider (bring-your-own-key). Users can also configure
# their own key in Settings; this is only the fallback default.
VITE_AI_BASE_URL=https://api.openai.com/v1
VITE_AI_API_KEY=
VITE_AI_MODEL=gpt-4o-mini
